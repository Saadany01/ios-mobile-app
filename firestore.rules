rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────

    /** True if the requesting user is authenticated */
    function isAuth() {
      return request.auth != null;
    }

    /** UID of the requesting user */
    function uid() {
      return request.auth.uid;
    }

    /** True if the requesting user has a profile doc */
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(uid()));
    }

    /** Lowercased username of requester, or empty if unavailable */
    function currentUsernameLowercase() {
      return hasUserDoc()
        ? (get(/databases/$(database)/documents/users/$(uid())).data.usernameLowercase is string
          ? get(/databases/$(database)/documents/users/$(uid())).data.usernameLowercase
          : '')
        : '';
    }

    /** True if requester is member of this chat doc */
    function isChatMember(chatData) {
      return uid() in chatData.memberIds;
    }

    // ── Active Calls ─────────────────────────────────────────────

    match /active_calls/{callId} {
      /** Only the caller or callee can read the call document */
      allow read: if isAuth()
        && (resource.data.callerId == uid()
         || resource.data.calleeId == uid());

      /** The caller creates the call with themselves as callerId */
      allow create: if isAuth()
        && request.resource.data.callerId == uid()
        && request.resource.data.calleeId != uid()
        && (request.resource.data.mediaType == 'audio'
         || request.resource.data.mediaType == 'video')
        && request.resource.data.status == 'ringing';

      /** Caller or callee can update (answer, decline, end, add SDP) */
      allow update: if isAuth()
        && (resource.data.callerId == uid()
         || resource.data.calleeId == uid())
        && request.resource.data.callerId == resource.data.callerId
        && request.resource.data.calleeId == resource.data.calleeId;

      /** No deletions from client-side */
      allow delete: if false;

      // ── ICE Candidates ───────────────────────────────────────

      match /callerCandidates/{candidateId} {
        /** Caller writes their own candidates, both parties can read */
        allow read: if isAuth()
          && (get(/databases/$(database)/documents/active_calls/$(callId)).data.callerId == uid()
           || get(/databases/$(database)/documents/active_calls/$(callId)).data.calleeId == uid());
        allow create: if isAuth()
          && get(/databases/$(database)/documents/active_calls/$(callId)).data.callerId == uid();
        allow update, delete: if false;
      }

      match /calleeCandidates/{candidateId} {
        /** Callee writes their own candidates, both parties can read */
        allow read: if isAuth()
          && (get(/databases/$(database)/documents/active_calls/$(callId)).data.callerId == uid()
           || get(/databases/$(database)/documents/active_calls/$(callId)).data.calleeId == uid());
        allow create: if isAuth()
          && get(/databases/$(database)/documents/active_calls/$(callId)).data.calleeId == uid();
        allow update, delete: if false;
      }
    }

    // ── Call History (per-user subcollection) ────────────────────

    match /users/{userId}/calls/{callId} {
      /** Users can read their own call history */
      allow read: if isAuth() && userId == uid();

      /** Users can write their own history, OR write the other party's history
          if they were a participant in that call (enables the history transaction) */
      allow write: if isAuth() && (
        userId == uid()
        || (
          exists(/databases/$(database)/documents/active_calls/$(callId))
          && (
            get(/databases/$(database)/documents/active_calls/$(callId)).data.callerId == uid()
            || get(/databases/$(database)/documents/active_calls/$(callId)).data.calleeId == uid()
          )
        )
      );
    }

    // ── User contacts (per-user subcollection) ───────────────────

    match /users/{userId}/contacts/{contactId} {
      allow read, write: if isAuth() && userId == uid();
    }

    // ── Friend requests ───────────────────────────────────────────

    match /friend_requests/{requestId} {
      function isRequestParticipant() {
        return resource.data.fromUserId == uid()
          || resource.data.toUserId == uid()
          || resource.data.toUsernameLowercase == currentUsernameLowercase();
      }

      function isRequestParticipantInWrite() {
        return request.resource.data.fromUserId == uid()
          || request.resource.data.toUserId == uid()
          || request.resource.data.toUsernameLowercase == currentUsernameLowercase();
      }

      allow read: if isAuth() && isRequestParticipant();

      allow create: if isAuth()
        && request.resource.data.fromUserId == uid()
        && request.resource.data.status == 'pending';

      allow update, delete: if isAuth()
        && (isRequestParticipant() || isRequestParticipantInWrite());
    }

    // ── Friendships ───────────────────────────────────────────────

    match /friendships/{friendshipId} {
      function isFriendshipMember() {
        return uid() in resource.data.memberIds;
      }

      function isFriendshipMemberInWrite() {
        return uid() in request.resource.data.memberIds;
      }

      allow read: if isAuth() && isFriendshipMember();
      allow create: if isAuth() && isFriendshipMemberInWrite();
      allow update, delete: if isAuth()
        && (isFriendshipMember() || isFriendshipMemberInWrite());
    }

    // ── Direct chats and messages ────────────────────────────────

    match /direct_chats/{chatId} {
      allow read: if isAuth() && isChatMember(resource.data);

      allow create: if isAuth() && isChatMember(request.resource.data);

      allow update, delete: if isAuth()
        && (isChatMember(resource.data) || isChatMember(request.resource.data));

      match /messages/{messageId} {
        allow read: if isAuth()
          && isChatMember(get(/databases/$(database)/documents/direct_chats/$(chatId)).data);

        allow create: if isAuth()
          && request.resource.data.senderId == uid()
          && isChatMember(get(/databases/$(database)/documents/direct_chats/$(chatId)).data);

        allow update, delete: if false;
      }
    }

    // ── Users collection (for FCM token and profile access) ─────

    match /users/{userId} {
      /** Any authenticated user can read basic profile info */
      allow read: if isAuth();

      /** Users can update their own document (e.g., FCM token) */
      allow update: if isAuth()
        && userId == uid()
        && request.resource.data.uid == resource.data.uid;

      /** Creation is handled by auth service / cloud functions */
      allow create: if isAuth() && request.resource.data.uid == uid();

      allow delete: if false;
    }

    // ── Deny everything else by default ──────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
